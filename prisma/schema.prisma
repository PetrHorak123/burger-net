generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Burger {
  id        String   @id
  price     Float
  rating    Int?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model User {
  id        String   @id
  alias     String
  email     String?
  burgers   Burger[]
  createdAt DateTime @default(now())
}
